generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id               String    @id @default(cuid())
  title            String
  slug             String    @unique
  shortDescription String
  fullDescription  String?
  highlights       String[]
  category         String?
  featured         Boolean   @default(false)
  active           Boolean   @default(true)
  displayOrder     Int       @default(0)
  packages         Package[]
  bookings         Booking[]
  inquiries        Inquiry[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([active, displayOrder])
  @@index([featured, active])
  @@map("services")
}

model Package {
  id           String    @id @default(cuid())
  serviceId    String
  service      Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name         String
  price        Decimal?  @db.Decimal(10, 2)
  description  String?
  inclusions   String[]
  active       Boolean   @default(true)
  displayOrder Int       @default(0)
  orders       Order[]
  bookings     Booking[]
  inquiries    Inquiry[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([serviceId])
  @@index([active, displayOrder])
  @@map("packages")
}

model PortfolioCategory {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  description  String?
  displayOrder Int              @default(0)
  images       PortfolioImage[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([displayOrder])
  @@map("portfolio_categories")
}

model PortfolioImage {
  id           String            @id @default(cuid())
  categoryId   String
  category     PortfolioCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title        String
  slug         String            @unique
  imageUrl     String
  altText      String
  description  String?
  featured     Boolean           @default(false)
  active       Boolean           @default(true)
  displayOrder Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([categoryId])
  @@index([active, displayOrder])
  @@index([featured, active])
  @@map("portfolio_images")
}

model Inquiry {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String?
  serviceType   String?
  serviceId     String?
  service       Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  packageId     String?
  package       Package?      @relation(fields: [packageId], references: [id], onDelete: SetNull)
  preferredDate DateTime?
  message       String
  status        InquiryStatus @default(NEW)
  notes         String?
  booking       Booking?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([serviceId])
  @@index([packageId])
  @@map("inquiries")
}

model Booking {
  id          String        @id @default(cuid())
  inquiryId   String?       @unique
  inquiry     Inquiry?      @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  serviceId   String?
  service     Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  packageId   String?
  package     Package?      @relation(fields: [packageId], references: [id], onDelete: SetNull)
  bookingDate DateTime?
  status      BookingStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([bookingDate])
  @@index([serviceId])
  @@index([packageId])
  @@map("bookings")
}

model Order {
  id            String        @id @default(cuid())
  packageId     String?
  package       Package?      @relation(fields: [packageId], references: [id], onDelete: SetNull)
  customerName  String
  phone         String
  email         String?
  totalAmount   Decimal       @db.Decimal(10, 2)
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  payments      Payment[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([paymentStatus])
  @@index([packageId])
  @@map("orders")
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider      String
  amount        Decimal       @db.Decimal(10, 2)
  status        PaymentStatus @default(PENDING)
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  role         AdminRole @default(ADMIN)
  passwordHash String
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([active])
  @@index([role])
  @@map("admin_users")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model AboutContent {
  id                String   @id
  heroEyebrow       String
  heroTitle         String
  heroSubtitle      String
  storyParagraph1   String
  storyParagraph2   String
  storyParagraph3   String
  highlightsEyebrow String
  highlightsTitle   String
  highlights        Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("about_content")
}

enum InquiryStatus {
  NEW
  CONTACTED
  BOOKED
  CLOSED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}
