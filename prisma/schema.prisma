generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Service {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  description    String
  galleryIntro   String?
  galleryClosing String?
  imageUrls      String[]  @default([])
  price          Decimal?  @db.Decimal(10, 2)
  inclusions     String[]
  featured       Boolean   @default(false)
  active         Boolean   @default(true)
  displayOrder   Int       @default(0)
  packages       Package[]
  inquiries      Inquiry[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([active, displayOrder])
  @@index([featured, active])
  @@map("services")
}

model Package {
  id           String    @id @default(cuid())
  serviceId    String
  service      Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name         String
  price        Decimal?  @db.Decimal(10, 2)
  description  String?
  inclusions   String[]
  active       Boolean   @default(true)
  displayOrder Int       @default(0)
  inquiries    Inquiry[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([serviceId])
  @@index([active, displayOrder])
  @@map("packages")
}

model Inquiry {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String?
  serviceType   String?
  serviceId     String?
  service       Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  packageId     String?
  package       Package?      @relation(fields: [packageId], references: [id], onDelete: SetNull)
  preferredDate DateTime?
  message       String
  status        InquiryStatus @default(NEW)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([serviceId])
  @@index([packageId])
  @@map("inquiries")
}

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  role         AdminRole @default(ADMIN)
  passwordHash String
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([active])
  @@index([role])
  @@map("admin_users")
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model AboutContent {
  id                String   @id
  heroEyebrow       String
  heroTitle         String
  heroSubtitle      String
  quoteText         String
  storyParagraph1   String
  storyParagraph2   String
  storyParagraph3   String
  timelineEyebrow   String
  timelineTitle     String
  timeline          Json
  highlightsEyebrow String
  highlightsTitle   String
  highlights        Json
  experienceEyebrow String
  experienceTitle   String
  experienceSteps   Json
  stats             Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("about_content")
}

enum InquiryStatus {
  NEW
  CONTACTED
  BOOKED
  CLOSED
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}
